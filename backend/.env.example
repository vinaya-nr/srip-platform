APP_NAME=srip-api
ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://srip:srip@postgres:5432/srip
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_MAXLEN=10000
CORS_ORIGINS=["http://localhost:3000"]
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/
